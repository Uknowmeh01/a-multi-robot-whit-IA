  ],
)

batteryWallSketch = sketch(on = faceOf(rearPlateCut, face = END)) {
  leftWallBottom = line(start = [var -40mm, var -64mm], end = [var -37mm, var -64mm])
  leftWallInner = line(start = [var -37mm, var -64mm], end = [var -37mm, var 12.5mm])
  rearWallInner = line(start = [var -37mm, var 12.5mm], end = [var 37mm, var 12.5mm])
  rightWallInner = line(start = [var 37mm, var 12.5mm], end = [var 37mm, var -64mm])
  rightWallBottom = line(start = [var 37mm, var -64mm], end = [var 40mm, var -64mm])
  rightWallOuter = line(start = [var 40mm, var -64mm], end = [var 40mm, var 15.5mm])
  rearWallOuter = line(start = [var 40mm, var 15.5mm], end = [var -40mm, var 15.5mm])
  leftWallOuter = line(start = [var -40mm, var 15.5mm], end = [var -40mm, var -64mm])

  coincident([
    leftWallBottom.end,
    leftWallInner.start
  ])
  coincident([leftWallInner.end, rearWallInner.start])
  coincident([
    rearWallInner.end,
    rightWallInner.start
  ])
  coincident([
    rightWallInner.end,
    rightWallBottom.start
  ])
  coincident([
    rightWallBottom.end,
    rightWallOuter.start
  ])
  coincident([
    rightWallOuter.end,
    rearWallOuter.start
  ])
  coincident([rearWallOuter.end, leftWallOuter.start])
  coincident([
    leftWallOuter.end,
    leftWallBottom.start
  ])
  horizontal(leftWallBottom)
  vertical(leftWallInner)
  horizontal(rearWallInner)
  vertical(rightWallInner)
  horizontal(rightWallBottom)
  vertical(rightWallOuter)
  horizontal(rearWallOuter)
  vertical(leftWallOuter)
  horizontalDistance([ORIGIN, leftWallBottom.start]) == -40mm
  verticalDistance([ORIGIN, leftWallBottom.start]) == -64mm
  distance([
  leftWallBottom.start,
  leftWallBottom.end
]) == wallThickness
  verticalDistance([leftWallInner.start, leftWallInner.end]) == 76.5mm
  distance([rearWallInner.start, rearWallInner.end]) == 74mm
  verticalDistance([
  rightWallInner.start,
  rightWallInner.end
]) == -76.5mm
  distance([
  rightWallBottom.start,
  rightWallBottom.end
]) == wallThickness
  verticalDistance([
  rightWallOuter.start,
  rightWallOuter.end
]) == 79.5mm
  distance([rearWallOuter.start, rearWallOuter.end]) == 80mm
}

batteryWallRegion = region(point = [-38.5mm, -20mm], sketch = batteryWallSketch)
export lowerRearPlateFinal = extrude(batteryWallRegion, length = 9mm, method = MERGE)
  |> appearance(color = "#c9822f", roughness = 62, metalness = 0)

hide(rearPlateSketch)
hide(batteryWallSketch)
lowerRearPlateFinal
