// Lower chassis rear printable section
// Rounded rear half with motor, battery, driver, power, routing, ventilation, splice, and spacer provisions.
@settings(defaultLengthUnit = mm)

import * from "parameters.kcl"
import unitBoxExport from "unitBox.kcl"
import unitCylinderExport from "unitCylinder.kcl"

zoneCutterCenterZ = basePlateThickness + 1mm - zoneRecessDepth

rearPlateSketch = sketch(on = XY) {
  spliceEdge = line(start = [var -100mm, var -70mm], end = [var 100mm, var -70mm])
  rightSide = line(start = [var 100mm, var -70mm], end = [var 100mm, var 60mm])
  rearRightArc = arc(start = [var 100mm, var 60mm], end = [var 90mm, var 70mm], center = [var 90mm, var 60mm])
  rearUpper = line(start = [var 90mm, var 70mm], end = [var -90mm, var 70mm])
  rearLeftArc = arc(start = [var -90mm, var 70mm], end = [var -100mm, var 60mm], center = [var -90mm, var 60mm])
  leftSide = line(start = [var -100mm, var 60mm], end = [var -100mm, var -70mm])

  coincident([spliceEdge.end, rightSide.start])
  coincident([rightSide.end, rearRightArc.start])
  coincident([rearRightArc.end, rearUpper.start])
  coincident([rearUpper.end, rearLeftArc.start])
  coincident([rearLeftArc.end, leftSide.start])
  coincident([leftSide.end, spliceEdge.start])
  horizontal(spliceEdge)
  vertical(rightSide)
  horizontal(rearUpper)
  vertical(leftSide)
  horizontal([
    rearRightArc.start,
    rearRightArc.center
  ])
  vertical([rearRightArc.center, rearRightArc.end])
  vertical([rearLeftArc.start, rearLeftArc.center])
  horizontal([rearLeftArc.center, rearLeftArc.end])
  horizontalDistance([ORIGIN, spliceEdge.start]) == -chassisWidth / 2
  verticalDistance([ORIGIN, spliceEdge.start]) == -splitSectionLength / 2
  distance([spliceEdge.start, spliceEdge.end]) == chassisWidth
  verticalDistance([rightSide.start, rightSide.end]) == splitSectionLength - cornerRadius
  equalLength([rightSide, leftSide])
  radius(rearRightArc) == cornerRadius
  radius(rearLeftArc) == cornerRadius
}

rearPlateBase = extrude(region(point = [0mm, 0mm], sketch = rearPlateSketch), length = basePlateThickness)

